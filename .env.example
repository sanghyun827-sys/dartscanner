# ── DART API ─────────────────────────────────────────────────────
# https://opendart.fss.or.kr 에서 발급
DART_API_KEY=your_dart_api_key_here

# ── Google Gemini API ─────────────────────────────────────────────
# https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# ── 모델 설정 ────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIM=768

# ── PostgreSQL ───────────────────────────────────────────────────
# docker-compose 사용 시 아래 값 그대로 사용
DATABASE_URL=postgresql+asyncpg://dart:dart@db:5432/dartscanner

# ── Google Cloud Storage (선택) ──────────────────────────────────
# 문서 ZIP 캐싱 용도. 없으면 비워두세요 (GCS 미사용)
GCS_BUCKET_NAME=
GCS_CREDENTIALS_PATH=

# ── RAG 튜닝 ─────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=5

# ── GCP VM (선택 - GPU 파싱용) ───────────────────────────────────
# GCP Compute Engine VM으로 임베딩을 실행할 경우 설정
GCP_PROJECT_ID=
GCP_ZONE=asia-northeast3-a
GCP_INSTANCE_NAME=
